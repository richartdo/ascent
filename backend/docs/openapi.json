{
  "openapi": "3.1.0",
  "info": { "title": "Ascent Backend API", "version": "1.0.0", "description": "Authenticated opportunity discovery, application tracking, synthetic-baseline matching, and optional locally generated summaries, readiness explanations, and CV analysis. Generated output comes from a pretrained model, requires human review, and never guarantees eligibility or success." },
  "servers": [{ "url": "http://localhost:5000", "description": "Local development" }],
  "tags": [
    { "name": "Platform" }, { "name": "Authentication" }, { "name": "Profiles" },
    { "name": "Opportunities" }, { "name": "Saved opportunities" }, { "name": "Applications" },
    { "name": "Notifications" }, { "name": "AI" }, { "name": "AI — deferred" }
  ],
  "paths": {
    "/api/v1/health": { "get": { "tags": ["Platform"], "summary": "Health check", "responses": { "200": { "$ref": "#/components/responses/Health" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/auth/me": { "get": { "tags": ["Authentication"], "summary": "Get authenticated user context", "security": [{ "bearerAuth": [] }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "429": { "$ref": "#/components/responses/RateLimited" }, "503": { "$ref": "#/components/responses/ServiceUnavailable" } } } },
    "/api/v1/profile": {
      "get": { "tags": ["Profiles"], "summary": "Get current user's profile", "security": [{ "bearerAuth": [] }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "429": { "$ref": "#/components/responses/RateLimited" } } },
      "patch": { "tags": ["Profiles"], "summary": "Create or update current user's profile", "security": [{ "bearerAuth": [] }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfilePatch" } } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } }
    },
    "/api/v1/opportunities": { "get": { "tags": ["Opportunities"], "summary": "List active published opportunities", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/Page" }, { "$ref": "#/components/parameters/Limit" }, { "name": "q", "in": "query", "schema": { "type": "string", "minLength": 2, "maxLength": 120 } }, { "name": "type", "in": "query", "schema": { "$ref": "#/components/schemas/OpportunityType" } }, { "name": "country", "in": "query", "schema": { "type": "string", "pattern": "^[A-Za-z]{2}$" } }, { "name": "isGlobal", "in": "query", "schema": { "type": "boolean" } }, { "name": "locationMode", "in": "query", "schema": { "type": "string", "enum": ["onsite", "hybrid", "remote", "unspecified"] } }, { "name": "deadlineBefore", "in": "query", "schema": { "type": "string", "format": "date-time" } }, { "name": "deadlineAfter", "in": "query", "schema": { "type": "string", "format": "date-time" } }, { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["deadline_asc", "deadline_desc", "published_desc"], "default": "published_desc" } }], "responses": { "200": { "$ref": "#/components/responses/Paginated" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/opportunities/{opportunityId}": { "get": { "tags": ["Opportunities"], "summary": "Get opportunity details", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/OpportunityId" }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/saved-opportunities": { "get": { "tags": ["Saved opportunities"], "summary": "List current user's saved opportunities", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/Page" }, { "$ref": "#/components/parameters/Limit" }], "responses": { "200": { "$ref": "#/components/responses/Paginated" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/saved-opportunities/{opportunityId}": {
      "post": { "tags": ["Saved opportunities"], "summary": "Save a published opportunity", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/OpportunityId" }], "requestBody": { "$ref": "#/components/requestBodies/SavedOpportunity" }, "responses": { "201": { "$ref": "#/components/responses/Created" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } },
      "patch": { "tags": ["Saved opportunities"], "summary": "Update saved-opportunity notes", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/OpportunityId" }], "requestBody": { "$ref": "#/components/requestBodies/SavedOpportunity" }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } },
      "delete": { "tags": ["Saved opportunities"], "summary": "Remove a saved opportunity", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/OpportunityId" }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "429": { "$ref": "#/components/responses/RateLimited" } } }
    },
    "/api/v1/applications": {
      "get": { "tags": ["Applications"], "summary": "List current user's applications", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/Page" }, { "$ref": "#/components/parameters/Limit" }, { "name": "status", "in": "query", "schema": { "$ref": "#/components/schemas/ApplicationStatus" } }, { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["updated_desc", "deadline_asc", "created_desc"], "default": "updated_desc" } }], "responses": { "200": { "$ref": "#/components/responses/Paginated" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } },
      "post": { "tags": ["Applications"], "summary": "Create an application tracker", "security": [{ "bearerAuth": [] }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApplicationCreate" } } } }, "responses": { "201": { "$ref": "#/components/responses/Created" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } }
    },
    "/api/v1/applications/{applicationId}": {
      "get": { "tags": ["Applications"], "summary": "Get an application", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/ApplicationId" }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } },
      "patch": { "tags": ["Applications"], "summary": "Update application status or notes", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/ApplicationId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApplicationPatch" } } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } },
      "delete": { "tags": ["Applications"], "summary": "Delete an application tracker", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/ApplicationId" }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "429": { "$ref": "#/components/responses/RateLimited" } } }
    },
    "/api/v1/applications/{applicationId}/checklist": { "patch": { "tags": ["Applications"], "summary": "Replace an application's checklist", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/ApplicationId" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChecklistUpdate" } } } }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/notifications": { "get": { "tags": ["Notifications"], "summary": "Synchronize and list notifications", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/Page" }, { "$ref": "#/components/parameters/Limit" }, { "name": "unreadOnly", "in": "query", "schema": { "type": "boolean", "default": false } }, { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["deadline", "application", "system"] } }], "responses": { "200": { "$ref": "#/components/responses/Paginated" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/notifications/unread-count": { "get": { "tags": ["Notifications"], "summary": "Get unread notification count", "security": [{ "bearerAuth": [] }], "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/notifications/{notificationId}/read": { "patch": { "tags": ["Notifications"], "summary": "Mark a notification read", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/NotificationId" }], "requestBody": { "$ref": "#/components/requestBodies/Empty" }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/notifications/{notificationId}/dismiss": { "patch": { "tags": ["Notifications"], "summary": "Dismiss a notification", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/NotificationId" }], "requestBody": { "$ref": "#/components/requestBodies/Empty" }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "404": { "$ref": "#/components/responses/NotFound" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/notifications/read-all": { "post": { "tags": ["Notifications"], "summary": "Mark all non-dismissed notifications read", "security": [{ "bearerAuth": [] }], "requestBody": { "$ref": "#/components/requestBodies/Empty" }, "responses": { "200": { "$ref": "#/components/responses/Success" }, "401": { "$ref": "#/components/responses/Unauthorized" }, "403": { "$ref": "#/components/responses/Forbidden" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" } } } },
    "/api/v1/ai/opportunity-matches": { "post": { "$ref": "#/components/x-operations/AiMatches" } },
    "/api/v1/ai/opportunities/{opportunityId}/summary": { "post": { "$ref": "#/components/x-operations/AiOpportunitySummary" } },
    "/api/v1/ai/opportunities/{opportunityId}/readiness": { "post": { "$ref": "#/components/x-operations/AiReadiness" } },
    "/api/v1/ai/cv-analysis": { "post": { "$ref": "#/components/x-operations/AiCv" } },
    "/api/v1/ai/opportunities/{opportunityId}/cover-letter": { "post": { "$ref": "#/components/x-operations/AiCoverLetter" } },
    "/api/v1/ai/essay-assistance": { "post": { "$ref": "#/components/x-operations/AiEssay" } }
  },
  "components": {
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "Supabase JWT", "description": "Supabase user access token, not the publishable key." } },
    "parameters": {
      "Page": { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 100000, "default": 1 } },
      "Limit": { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 20 } },
      "OpportunityId": { "name": "opportunityId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
      "ApplicationId": { "name": "applicationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
      "NotificationId": { "name": "notificationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
    },
    "requestBodies": {
      "Empty": { "required": false, "content": { "application/json": { "schema": { "type": "object", "additionalProperties": false } } } },
      "SavedOpportunity": { "required": true, "content": { "application/json": { "schema": { "type": "object", "additionalProperties": false, "properties": { "notes": { "type": ["string", "null"], "maxLength": 2000 } } } } } }
    },
    "schemas": {
      "OpportunityType": { "type": "string", "enum": ["scholarship", "internship", "job", "grant", "fellowship", "competition", "accelerator", "hackathon", "training"] },
      "ApplicationStatus": { "type": "string", "enum": ["planning", "preparing", "submitted", "under_review", "shortlisted", "accepted", "rejected", "withdrawn"] },
      "ProfilePatch": { "type": "object", "additionalProperties": false, "minProperties": 1, "properties": { "persona": { "type": ["string", "null"], "enum": ["student", "recent_graduate", "young_founder", null] }, "fullName": { "type": ["string", "null"], "maxLength": 120 }, "countryCode": { "type": ["string", "null"], "pattern": "^[A-Za-z]{2}$" }, "city": { "type": ["string", "null"], "maxLength": 120 }, "educationLevel": { "type": ["string", "null"], "enum": ["secondary", "undergraduate", "postgraduate", "graduate", "other", null] }, "institution": { "type": ["string", "null"], "maxLength": 180 }, "fieldOfStudy": { "type": ["string", "null"], "maxLength": 180 }, "graduationYear": { "type": ["integer", "null"] }, "skills": { "type": "array", "maxItems": 50, "items": { "type": "string", "maxLength": 80 } }, "interests": { "type": "array", "maxItems": 50, "items": { "type": "string", "maxLength": 80 } }, "careerGoals": { "type": ["string", "null"], "maxLength": 2000 }, "preferredOpportunityTypes": { "type": "array", "maxItems": 9, "items": { "$ref": "#/components/schemas/OpportunityType" } }, "preferredLocations": { "type": "array", "maxItems": 25, "items": { "type": "string", "maxLength": 120 } }, "remotePreference": { "type": ["string", "null"], "enum": ["remote_only", "remote_preferred", "no_preference", null] } } },
      "ApplicationCreate": { "type": "object", "additionalProperties": false, "required": ["opportunityId"], "properties": { "opportunityId": { "type": "string", "format": "uuid" }, "status": { "$ref": "#/components/schemas/ApplicationStatus" }, "notes": { "type": ["string", "null"], "maxLength": 5000 }, "nextStep": { "type": ["string", "null"], "maxLength": 1000 } } },
      "ApplicationPatch": { "type": "object", "additionalProperties": false, "minProperties": 1, "properties": { "status": { "$ref": "#/components/schemas/ApplicationStatus" }, "notes": { "type": ["string", "null"], "maxLength": 5000 }, "nextStep": { "type": ["string", "null"], "maxLength": 1000 } } },
      "ChecklistUpdate": { "type": "object", "additionalProperties": false, "required": ["checklist"], "properties": { "checklist": { "type": "array", "maxItems": 25, "items": { "type": "object", "additionalProperties": false, "required": ["id", "title", "completed"], "properties": { "id": { "type": "string", "format": "uuid" }, "title": { "type": "string", "minLength": 1, "maxLength": 160 }, "completed": { "type": "boolean" }, "completedAt": { "type": ["string", "null"], "format": "date-time" } } } } } },
      "Error": { "type": "object", "additionalProperties": false, "required": ["error"], "properties": { "error": { "type": "object", "additionalProperties": false, "required": ["code", "message", "requestId"], "properties": { "code": { "type": "string" }, "message": { "type": "string" }, "requestId": { "type": "string", "format": "uuid" }, "details": {} } } } },
      "SuccessEnvelope": { "type": "object", "required": ["data"], "properties": { "data": { "type": ["object", "array"] }, "meta": { "type": "object", "properties": { "requestId": { "type": "string", "format": "uuid" } } } } },
      "PaginatedEnvelope": { "type": "object", "required": ["data", "meta"], "properties": { "data": { "type": "array", "items": {} }, "meta": { "type": "object", "required": ["page", "limit", "total", "totalPages", "requestId"], "properties": { "page": { "type": "integer" }, "limit": { "type": "integer" }, "total": { "type": "integer" }, "totalPages": { "type": "integer" }, "requestId": { "type": "string", "format": "uuid" } } } } },
      "AiMatchesRequest": { "type": "object", "additionalProperties": false, "properties": { "limit": { "type": "integer", "minimum": 1, "maximum": 25, "default": 10 } } },
      "AiMatchesResponse": { "type": "object", "additionalProperties": false, "required": ["data", "meta"], "properties": { "data": { "type": "object", "additionalProperties": false, "required": ["matches"], "properties": { "matches": { "type": "array", "items": { "$ref": "#/components/schemas/MatchingResult" } } } }, "meta": { "type": "object", "additionalProperties": false, "required": ["requestId"], "properties": { "requestId": { "type": "string", "format": "uuid" } } } } },
      "CvRequest": { "type": "object", "additionalProperties": false, "required": ["cvText"], "description": "Omit opportunityId for general CV analysis, or provide it for relevance analysis against an RLS-visible server-loaded opportunity. Raw opportunity fields are never accepted.", "properties": { "cvText": { "type": "string", "minLength": 1, "maxLength": 20000, "example": "Fictional candidate completed a class project using JavaScript." }, "opportunityId": { "type": "string", "format": "uuid" } } },
      "CoverLetterRequest": { "type": "object", "additionalProperties": false, "properties": { "tone": { "type": "string", "enum": ["professional", "warm", "concise"], "default": "professional" }, "instructions": { "type": "string", "maxLength": 1000 } } },
      "EssayRequest": { "type": "object", "additionalProperties": false, "required": ["mode", "prompt"], "properties": { "mode": { "type": "string", "enum": ["brainstorm", "outline", "feedback", "revise"] }, "prompt": { "type": "string", "maxLength": 3000 }, "draft": { "type": "string", "maxLength": 30000 } } },
      "MatchingResult": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "opportunityId", "matchScore", "eligibilityAssessment", "reasons", "matchedCriteria", "gaps", "disclaimer"], "properties": { "schemaVersion": { "const": "1.0" }, "opportunityId": { "type": "string", "format": "uuid" }, "matchScore": { "type": "integer", "minimum": 0, "maximum": 100 }, "eligibilityAssessment": { "type": "string", "enum": ["likely", "uncertain", "unlikely"] }, "reasons": { "$ref": "#/components/schemas/AiStringList10" }, "matchedCriteria": { "$ref": "#/components/schemas/AiStringList10" }, "gaps": { "$ref": "#/components/schemas/AiStringList10" }, "disclaimer": { "const": "This assessment is guidance, not an eligibility guarantee." } } },
      "AiStringList": { "type": "array", "maxItems": 12, "items": { "type": "string", "minLength": 1, "maxLength": 300 } },
      "AiStringList10": { "type": "array", "maxItems": 10, "items": { "type": "string", "minLength": 1, "maxLength": 300 } },
      "AiStringList8": { "type": "array", "maxItems": 8, "items": { "type": "string", "minLength": 1, "maxLength": 300 } },
      "OpportunitySummaryResult": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "opportunityId", "summary", "eligibilityHighlights", "benefits", "deadlineNotes", "missingInformation", "disclaimer"], "properties": { "schemaVersion": { "const": "1.0" }, "opportunityId": { "type": "string", "format": "uuid" }, "summary": { "type": "string", "maxLength": 1500 }, "eligibilityHighlights": { "$ref": "#/components/schemas/AiStringList10" }, "benefits": { "$ref": "#/components/schemas/AiStringList10" }, "deadlineNotes": { "type": "string", "maxLength": 500 }, "missingInformation": { "$ref": "#/components/schemas/AiStringList10" }, "disclaimer": { "const": "This summary is guidance; verify all details with the official opportunity source." } } },
      "ReadinessComponent30": { "type": "object", "additionalProperties": false, "required": ["earned", "maximum"], "properties": { "earned": { "type": "integer", "minimum": 0, "maximum": 30 }, "maximum": { "const": 30 } } },
      "ReadinessComponent20": { "type": "object", "additionalProperties": false, "required": ["earned", "maximum"], "properties": { "earned": { "type": "integer", "minimum": 0, "maximum": 20 }, "maximum": { "const": 20 } } },
      "ReadinessResult": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "opportunityId", "readinessScore", "assessment", "eligibilityAssessment", "components", "explanation", "strengths", "gaps", "actions", "missingInformation", "disclaimer"], "properties": { "schemaVersion": { "const": "1.0" }, "opportunityId": { "type": "string", "format": "uuid" }, "readinessScore": { "type": "integer", "minimum": 0, "maximum": 100, "description": "Deterministic preparation score, not a probability of selection." }, "assessment": { "type": "string", "enum": ["ready", "needs_preparation", "substantial_gaps"] }, "eligibilityAssessment": { "type": "string", "enum": ["likely", "uncertain", "unlikely"] }, "components": { "type": "object", "additionalProperties": false, "required": ["profileCompleteness", "eligibilityCompatibility", "preferenceFit", "skillEvidence"], "properties": { "profileCompleteness": { "$ref": "#/components/schemas/ReadinessComponent30" }, "eligibilityCompatibility": { "$ref": "#/components/schemas/ReadinessComponent30" }, "preferenceFit": { "$ref": "#/components/schemas/ReadinessComponent20" }, "skillEvidence": { "$ref": "#/components/schemas/ReadinessComponent20" } } }, "explanation": { "type": "string", "maxLength": 1200 }, "strengths": { "$ref": "#/components/schemas/AiStringList10" }, "gaps": { "$ref": "#/components/schemas/AiStringList10" }, "actions": { "$ref": "#/components/schemas/AiStringList10" }, "missingInformation": { "$ref": "#/components/schemas/AiStringList10" }, "disclaimer": { "const": "This readiness assessment is guidance, not a guarantee of eligibility or selection." } } },
