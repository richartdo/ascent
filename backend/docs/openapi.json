      "AiReadiness": { "tags": ["AI"], "summary": "Assess preparation for a verified opportunity", "description": "The numeric score, component points, band, and eligibility assessment are deterministic. The pretrained model explains strengths, gaps, and actions but cannot alter those values. This is not a probability of selection.", "security": [{ "bearerAuth": [] }], "parameters": [{ "$ref": "#/components/parameters/OpportunityId" }], "requestBody": { "$ref": "#/components/requestBodies/Empty" }, "responses": { "200": { "description": "Deterministic score with generated explanation", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AiReadinessResponse" } } } }, "401": { "$ref": "#/components/responses/Unauthorized" }, "404": { "$ref": "#/components/responses/NotFound" }, "409": { "$ref": "#/components/responses/Conflict" }, "422": { "$ref": "#/components/responses/ValidationError" }, "429": { "$ref": "#/components/responses/RateLimited" }, "502": { "$ref": "#/components/responses/AiMalformedResponse" }, "503": { "$ref": "#/components/responses/AiMatchingUnavailable" }, "504": { "$ref": "#/components/responses/AiTimeout" } } },
